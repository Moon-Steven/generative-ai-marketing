generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  planTier  String   @default("free") // free | pro | scale | enterprise
  createdAt DateTime @default(now())

  metaAccounts MetaAccount[]
  products     Product[]
  campaigns    Campaign[]
  creatives    Creative[]
}

model MetaAccount {
  id              String   @id @default(cuid())
  userId          String
  metaAccountId   String
  tokenRef        String   @default("") // reference to secrets manager
  status          String   @default("connected") // connected | expired | revoked
  lastSyncedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Product {
  id             String   @id @default(cuid())
  userId         String
  name           String
  description    String   @default("")
  price          Float    @default(0)
  currency       String   @default("USD")
  images         String   @default("[]") // JSON array of URLs
  sourceUrl      String   @default("")
  sourcePlatform String   @default("manual") // shopify | manual | other
  createdAt      DateTime @default(now())

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns Campaign[]
}

model Campaign {
  id              String   @id @default(cuid())
  userId          String
  productId       String
  metaCampaignId  String   @default("")
  name            String
  status          String   @default("draft") // draft | active | paused | completed | error
  dailyBudget     Float    @default(0)
  totalBudget     Float    @default(0)
  minRoas         Float    @default(1.0)
  currency        String   @default("USD")
  targetMarket    String   @default("")
  targetAudience  String   @default("") // JSON
  startDate       DateTime @default(now())
  createdAt       DateTime @default(now())

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  product         Product           @relation(fields: [productId], references: [id])
  creatives       Creative[]
  metrics         CampaignMetric[]
  audienceMetrics AudienceMetric[]
  optimizations   Optimization[]
}

model Creative {
  id           String   @id @default(cuid())
  userId       String
  campaignId   String
  type         String   @default("image") // image | video
  headline     String   @default("")
  bodyText     String   @default("")
  cta          String   @default("")
  assetUrl     String   @default("")
  thumbnailUrl String   @default("")
  sizes        String   @default("{}") // JSON: { "1:1": url, "9:16": url }
  status       String   @default("draft") // draft | live | paused | retired
  predictedCtr Float    @default(0)
  ctr          Float    @default(0)
  roas         Float    @default(0)
  image        String   @default("") // emoji or image ref for prototype
  createdAt    DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}

model CampaignMetric {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime
  spend       Float    @default(0)
  revenue     Float    @default(0)
  orders      Int      @default(0)
  roas        Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  cpc         Float    @default(0)
  cpa         Float    @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date])
}

model AudienceMetric {
  id          String   @id @default(cuid())
  campaignId  String
  date        DateTime @default(now())
  segmentKey  String   // e.g. "25-28M"
  percentage  Float    @default(0)
  spend       Float    @default(0)
  revenue     Float    @default(0)
  roas        Float    @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, date, segmentKey])
}

model Optimization {
  id             String   @id @default(cuid())
  campaignId     String
  type           String   // budget | creative | audience | pause
  status         String   @default("proposed") // proposed | accepted | rejected | applied | reverted
  description    String   @default("")
  expectedImpact String   @default("")
  riskLevel      String   @default("low") // low | medium | high
  proposedAt     DateTime @default(now())
  appliedAt      DateTime?

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
}
